<form class="ui stacked segment form" action="/dashboard/addplaylist" method="POST">
  <div class="three fields">
    <div class="field">
      <label>Title</label>
      <input placeholder="Title" type="text" name="title" autofocus required>
    </div>
    <div class="field">
      <label>&nbsp;</label>
      <input type="number" name="rating" min="1" max="5" placeholder="Rating" id="ratingNumber">
    </div>
    <div class="field">
      <label>Rating</label>
      <div class="ui blue slider" id="ratingSlider"></div>
      <input type="hidden" name="rating" id="ratingValue" value="1">
    </div>
    
  </div>
  
  <button class="ui blue submit button">Add Playlist</button>
</form>


